generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  INDIVIDUAL
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum Role {
  ADMIN
  MEMBER
}

model Organization {
  id                   String       @id @default(uuid())
  name                 String
  planType             PlanType     @default(INDIVIDUAL)
  billingCycle         BillingCycle @default(MONTHLY)
  maxSeats             Int          @default(1)
  stripeSubscriptionId String?

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  users                User[]
  appraisals           Appraisal[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @unique
  passwordHash   String
  name           String?
  role           Role         @default(ADMIN)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  createdAppraisals Appraisal[]
}

model Appraisal {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  createdByUserId  String
  createdByUser    User         @relation(fields: [createdByUserId], references: [id])

  clientName       String?
  propertyAddress  String?
  status           String       @default("draft")
  
  remoteId         String?      @unique

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  improvement      Improvement?
  siteDescription  SiteDescription?
  sketch           Sketch?
  photos           Photo[]
}

model Improvement {
  id              String    @id @default(uuid())
  appraisalId     String    @unique
  appraisal       Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  data            Json?     // Stores all improvement form fields as a JSON blob for flexibility
  
  updatedAt       DateTime  @updatedAt
}

model SiteDescription {
  id              String    @id @default(uuid())
  appraisalId     String    @unique
  appraisal       Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  topography      String?
  grade           String?
  cornerLot       Boolean?
  
  updatedAt       DateTime  @updatedAt
}

model Sketch {
  id              String    @id @default(uuid())
  appraisalId     String    @unique
  appraisal       Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  data            String?   // JSON string of sketch points/lines
  
  updatedAt       DateTime  @updatedAt
}

model Photo {
  id              String    @id @default(uuid())
  appraisalId     String
  appraisal       Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  fileName        String
  s3Key           String?   // Key in DO Spaces
  url             String?   // Public/private URL
  timestamp       DateTime?
  caption         String?
  latitude        Float?
  longitude       Float?

  updatedAt       DateTime  @updatedAt
}
